generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String       @id @default(cuid())
  telegramUserId BigInt       @unique
  username       String?
  firstName      String?
  lastName       String?
  photoUrl       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  memberships    TeamMember[]
}

model Team {
  id           String        @id @default(cuid())
  name         String
  plan         String        @default("free")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  members      TeamMember[]
  projects     Project[]
  roleMappings RoleMapping[]
  importDrafts ImportDraft[]
  contentItems ContentItem[]
  tasks        Task[]
}

model TeamMember {
  id            String   @id @default(cuid())
  teamId        String
  userId        String?
  name          String
  username      String?
  roleLabel     String?
  avatarEmoji   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignedTasks Task[]   @relation("AssignedTasks")
  roleMappings  RoleMapping[]

  @@index([teamId])
  @@index([userId])
}

model Project {
  id           String        @id @default(cuid())
  teamId       String
  name         String
  description  String?
  color        String?
  archived     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  roleMappings RoleMapping[]
  importDrafts ImportDraft[]
  contentItems ContentItem[]
  tasks        Task[]

  @@index([teamId])
}

model RoleMapping {
  id        String     @id @default(cuid())
  teamId    String
  projectId String
  role      String
  memberId  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member    TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([projectId, role])
  @@index([teamId])
  @@index([projectId])
}

model ImportDraft {
  id        String   @id @default(cuid())
  teamId    String
  projectId String
  source    String
  rawText   String
  rows      Json
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([projectId])
}

model ContentItem {
  id             String   @id @default(cuid())
  teamId         String
  projectId      String
  title          String
  format         String
  publishDate    DateTime
  topic          String?
  notes          String?
  expert         String?
  status         String   @default("idea")
  importSource   String   @default("manual")
  sourceImportId String?
  confidence     Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks          Task[]

  @@index([teamId])
  @@index([projectId])
}

model Task {
  id            String       @id @default(cuid())
  teamId        String
  projectId     String
  contentItemId String?
  title         String
  description   String?
  assigneeId    String?
  role          String?
  dueDate       DateTime?
  status        String       @default("todo")
  priority      String       @default("normal")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  team          Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contentItem   ContentItem? @relation(fields: [contentItemId], references: [id], onDelete: SetNull)
  assignee      TeamMember?  @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}
